{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "crons": [
    {
      "path": "/api/cron/scheduler",
      "schedule": "0 0 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}