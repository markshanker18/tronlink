# ================================
# CryptoPay Environment Variables
# ================================

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Session ---
SESSION_SECRET=your-session-secret-here

# --- Encryption ---
# Optional but strongly recommended: 32-byte key for encrypting executor keys (base64 or 64-char hex).
# If omitted, the app falls back to SESSION_SECRET-derived encryption.
ENCRYPTION_MASTER_KEY=your-32-byte-key-base64-or-hex

# --- Vercel Cron Auth ---
# Required in production to protect /api/cron/scheduler
CRON_SECRET=your-strong-random-cron-secret

# --- Contract Deployment ---
# Private key of the wallet used to deploy smart contracts
DEPLOYER_PRIVATE_KEY=your-deployer-private-key

# --- Executor (Automatic Payment Execution) ---
# Fallback executor private key (if not set per-user in dashboard)
EXECUTOR_PRIVATE_KEY=your-executor-private-key

# --- RPC Overrides (recommended) ---
# Use a stable RPC in production (scheduler + server-side cancel use this)
SEPOLIA_RPC_URL=https://your-sepolia-rpc.example
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}

# --- RPC Timeouts (optional) ---
# Bounds JSON-RPC HTTP request timeouts used by the backend (verification + scheduler).
# Default: 8000
RPC_TIMEOUT_MS=8000

# --- Transaction Finality (optional) ---
# Number of confirmations to wait before treating scheduler executions as final.
# Default: 3
TX_CONFIRMATIONS=3

# --- Pending TX Recovery (optional) ---
# If a broadcast tx hash stays pending without a retrievable receipt for too long,
# scheduler clears its pending lock so future runs can continue.
# Default: 1800000 (30 minutes)
PENDING_TX_MAX_AGE_MS=1800000

# --- Block Explorer Verification (optional) ---
ETHERSCAN_API_KEY=your-etherscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key

# ============================
# TRON Configuration
# ============================

# --- TRON RPC Nodes ---
TRON_MAINNET_FULL_NODE=https://api.trongrid.io
TRON_MAINNET_SOLIDITY_NODE=https://api.trongrid.io
TRON_MAINNET_EVENT_SERVER=https://api.trongrid.io
# API key from https://www.trongrid.io/ (required for production mainnet rate limits)
TRON_MAINNET_API_KEY=

# Nile testnet (default uses public node)
TRON_NILE_FULL_NODE=https://nile.trongrid.io
TRON_NILE_API_KEY=your-tron-nile-api-key

# --- TRON Execution ---
# Separate executor key for TRON (uses TRX/TVM). Can be the same key as EXECUTOR_PRIVATE_KEY
# if the wallet holds both ETH and TRX. Private key in hex (no 0x prefix) or base58.
TRON_EXECUTOR_PRIVATE_KEY=

# Fee limit in SUN for TRON smart contract calls (100 TRX = 100_000_000 SUN).
# Increase if contract calls fail with "REVERT opcode" or fee limit exceeded.
TRON_FEE_LIMIT_SUN=100000000

# Number of 3-second polls to wait for TRON tx solidification (default: 20 = ~60s)
TRON_CONFIRMATION_POLLS=20

# --- QR Signing ---
# HMAC-SHA256 secret for signing QR payloads. Use a strong random value in production.
# If omitted in development, falls back to SESSION_SECRET + "-qr-payload-v1".
QR_SIGNING_SECRET=

# TTL for signed QR payloads in hours (default: 168 = 7 days)
QR_PAYLOAD_TTL_HOURS=168

# --- Scheduler (optional overrides) ---
# How often the scheduler checks for due subscriptions in ms (default: 15000)
SCHEDULER_CHECK_INTERVAL_MS=15000
